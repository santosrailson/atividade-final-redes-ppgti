# Arquivos transitórios; CSVs, logs, resumos e gráficos das execuções finais
# devem ser versionados para permitir auditoria e reprodução do artigo.
resultados/sinal_controle_qos
!requirements.txt
!resultados/**/*.txt
!resultados/**/*.log
!resultados/*.txt

# Material de apoio para escrever o artigo (papers de referencia de
# terceiros). Nenhum script do projeto depende desses arquivos para
# rodar; ficam apenas locais, fora do repositorio.
artigos/

__pycache__/
*.pyc
.DS_Store
